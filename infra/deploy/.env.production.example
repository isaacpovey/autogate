# Copy to `.env.production` ON THE HOST and fill in real secrets.
# This file is the committed template — never put real secrets here.

# --- Public endpoint -------------------------------------------------------
# Bare hostname Caddy serves (no scheme).
SITE_ADDRESS=autogate.tyrongarratt.com
# Full public origin (scheme + host). Used for CORS + the browser API base URL.
PUBLIC_URL=https://autogate.tyrongarratt.com
ACME_EMAIL=admin@tyrongarratt.com

# --- TLS mode --------------------------------------------------------------
# Pre-DNS (before autogate.tyrongarratt.com resolves to 13.239.41.73):
#   self-signed cert via Caddy's internal CA, endpoint testable immediately.
TLS_DIRECTIVE=tls internal
#
# Once DNS is live, comment the line above and UNCOMMENT the empty assignment
# below, then restart Caddy. Empty => Caddy auto-issues a Let's Encrypt cert.
# TLS_DIRECTIVE=

# --- Datastore -------------------------------------------------------------
POSTGRES_PASSWORD=autogate

# --- Model providers -------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# --- Orchestrator worker ---------------------------------------------------
WORKER_POLL_INTERVAL_MS=2000

# --- GitHub App ------------------------------------------------------------
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_INSTALLATION_ID=
GITHUB_WEBHOOK_PROXY_URL=
