# Monorepo build context is the repo root (see docker-compose.yml `context: ..`).
FROM node:22-alpine

ENV CI=true

RUN corepack enable

WORKDIR /app

# Copy the whole workspace so pnpm can resolve workspace:* links.
COPY . .

RUN pnpm install --frozen-lockfile

WORKDIR /app/apps/api

EXPOSE 4000

CMD ["pnpm", "start"]
