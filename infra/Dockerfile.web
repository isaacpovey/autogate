# Monorepo build context is the repo root (see docker-compose.yml `context: ..`).
FROM node:22-alpine

ENV CI=true

RUN corepack enable

WORKDIR /app

# `NEXT_PUBLIC_*` vars are inlined into the client bundle at build time, so the
# public API URL must be present during `next build` — runtime env is too late
# for browser code.
ARG NEXT_PUBLIC_API_URL=http://localhost:3002
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

COPY . .

RUN pnpm install --frozen-lockfile
RUN pnpm --filter web build

WORKDIR /app/apps/web

EXPOSE 3000

CMD ["pnpm", "start"]
