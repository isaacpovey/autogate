# Orchestrator worker: same image as the api, different entrypoint.
# Drains the Postgres job queue and runs the L2 agent pipeline.
# Monorepo build context is the repo root (see docker-compose.yml `context: ..`).
FROM node:22-alpine

RUN corepack enable

WORKDIR /app

COPY . .

RUN pnpm install --frozen-lockfile

WORKDIR /app/apps/api

# The orchestrator worker entrypoint is provided by ticket 01 (apps/api).
# Scale horizontally with: docker-compose up --scale worker=N
CMD ["pnpm", "start"]
