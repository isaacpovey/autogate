{
  "name": "autogate",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "agent": "tsx packages/cli/src/index.ts agent",
    "eval": "tsx packages/cli/src/index.ts eval"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "tsx": "^4.20.6",
    "turbo": "^2.9.18",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=18"
  }
}
