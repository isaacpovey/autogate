{
  "name": "api",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "exports": {
    "./orchestrator": "./src/orchestrator/index.ts"
  },
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env src/index.ts",
    "dev:mock": "tsx watch src/mock-server.ts",
    "start": "tsx --env-file-if-exists=../../.env src/index.ts",
    "worker": "tsx --env-file-if-exists=../../.env src/worker.ts",
    "seed-fixture": "tsx --env-file-if-exists=../../.env src/seed-fixture.ts",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "smoke": "tsx --env-file-if-exists=../../.env smoke.ts"
  },
  "dependencies": {
    "@autogate/agent-claude": "workspace:*",
    "@autogate/agents": "workspace:*",
    "@autogate/api": "workspace:*",
    "@autogate/contracts": "workspace:*",
    "@autogate/evals": "workspace:*",
    "@autogate/infra": "workspace:*",
    "@autogate/sandbox": "workspace:*",
    "@autogate/store-postgres": "workspace:*",
    "@trpc/server": "^11.17.0",
    "cors": "^2.8.6"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/cors": "^2.8.17",
    "@types/node": "^22.15.3",
    "eslint": "^9.39.1",
    "tsx": "^4.22.4",
    "typescript": "5.9.2"
  }
}
